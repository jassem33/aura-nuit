# ===========================================
# Aura Nuit — Variables d'environnement
# Copier ce fichier vers .env.local et remplir.
# ===========================================

# --- Supabase ---
# Tableau de bord : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Administration ---
# Mot de passe d'accès au tableau de bord /admin
ADMIN_PASSWORD=changer-ce-mot-de-passe-immediatement
# Secret utilisé pour signer le cookie de session admin (≥ 32 caractères aléatoires)
ADMIN_SESSION_SECRET=remplacer-par-une-chaine-aleatoire-tres-longue-et-secrete

# --- UploadThing ---
# Tableau de bord : https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your-uploadthing-token
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxx
